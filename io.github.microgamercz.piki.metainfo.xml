<component type="desktop-application">
   <id>io.github.microgamercz.piki</id>
   <name>Piki</name>

   <developer id="io.github">
     <name>Micro</name>
   </developer>

   <summary>Browse illustrations and manga</summary>
   <summary xml:lang="cs">Prohlížej ilustrace a mangy</summary>

   <metadata_license>FSFAP</metadata_license>
   <project_license>GPL-3.0-or-later</project_license>
   <url type="homepage">https://github.com/MicrogamerCz/Piki</url>
   <keywords>
    <keyword>Pixiv</keyword>
    <keyword>Kirigami</keyword>
    <keyword>Qt</keyword>
    <keyword>Anime</keyword>
    <keyword>Art</keyword>
    <keyword>Otaku</keyword>
    <category>Feed</category>
    <category>Adult</category>
    <category>Network</category>
   </keywords>
   <provides>
    <binary>piki</binary>
   </provides>

   <content_rating type="oars-1.1">
     <content_attribute id="violence-cartoon">intense</content_attribute>
     <content_attribute id="violence-fantasy">intense</content_attribute>
     <content_attribute id="violence-realistic">intense</content_attribute>
     <content_attribute id="violence-bloodshed">intense</content_attribute>
     <content_attribute id="violence-sexual">intense</content_attribute>
     <content_attribute id="violence-desecration">intense</content_attribute>
     <content_attribute id="violence-slavery">intense</content_attribute>
     <content_attribute id="sex-nudity">intense</content_attribute>
     <content_attribute id="sex-themes">intense</content_attribute>
     <content_attribute id="social-contacts">intense</content_attribute>
   </content_rating>


   <supports>
     <control>pointing</control>
     <control>keyboard</control>
     <control>touch</control>
   </supports>

   <description>
     <p>
        Pixiv desktop client with multi-account support and desktop integration. Browse illustrations and manga, search works, set any illustration as wallpaper, bookmark works and follow your favourite creators.
     </p>
     <p xml:lang="cs">
        Nativní Pixiv aplikace s podporou více účtů a s integrací prostředí. Prohlížej a vyhledávej ilustrace a mangy, nastav si libovolnou jako tapetu, ukládej do záložek a sleduj své oblíbené tvůrce.
     </p>
   </description>

   <launchable
        type="desktop-id"
    >io.github.microgamercz.piki.desktop</launchable>
   <screenshots>
     <screenshot type="default">
       <image
            >https://raw.githubusercontent.com/MicrogamerCz/Piki/refs/heads/main/screenshots/2_home_light.png</image>
        <caption>Home page with feed in adaptive grid layout</caption>
     </screenshot>
     <screenshot>
       <image
            >https://raw.githubusercontent.com/MicrogamerCz/Piki/refs/heads/main/screenshots/3_illust_view_light.png</image>
        <caption
            >Illustration page, with pages on the left side and work info, related works, etc. on the right side</caption>
     </screenshot>
     <screenshot>
       <image
            >https://raw.githubusercontent.com/MicrogamerCz/Piki/refs/heads/main/screenshots/4_profile_view_light.png</image>
        <caption
            >Page showing user info and illustration, manga or novel feeds</caption>
     </screenshot>
   </screenshots>

   <branding>
     <color type="primary" scheme_preference="light">#82deff</color>
     <color type="primary" scheme_preference="dark">#186f9c</color>
   </branding>

   <releases>
    <release version="0.4.0" date="2026-07-20">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.4.0</url>
        <description>
        <ul>
          <li>Added Dutch translation by Vistaus</li>
          <li
                    >Added OpenSUSE installation instructions to README by Daskashk</li>
          <li
                    >Added discovery keywords to desktop entry, Arch packaging dependency fix by abdul-rafay-mirza</li>
          <li>Improved UI performance for feeds</li>
          <li>App and code maintanence</li>
        </ul>
        </description>
    </release>
    <release version="0.3.2" date="2025-08-09">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.3.2</url>
        <description>
        <p
                >Switched from KWallet to QtKeychain for better compatibility on environments without KWallet</p>
        </description>
    </release>
    <release version="0.3.1" date="2025-08-07">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.3.1</url>
        <description>
        <p
                >Fixes crashes on desktops without a keyring provider (without KWallet, Gnome keyring, etc.)</p>
        </description>
    </release>
    <release version="0.3.0" date="2025-08-03">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.3.0</url>
        <description>
        <p
                >Plentiful improvements - from small internal and UI tweaks to more features</p>
        <p>Features:</p>
        <p
                >- Share menu with a few common options, improved "Set as wallpaper" option</p>
        <p
                >- Novel option in feed pages categories and novels reading (reader is barebones - passing HTML data into a webview)</p>
        <p>- Pasting URL or work ID in search box opens the work</p>
        <p
                >- Added series, option to add/remove from watchlist, added series section on work page</p>
        <p>- Added Watchlist feed (= followed series)</p>
        </description>
    </release>
    <release version="0.2.0" date="2025-07-03">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.2.0</url>
        <description>
        <p
                >Plentiful improvements - from small internal and UI tweaks to more features</p>
        <p>Features:</p>
        <p>- Startup page options</p>
        <p>- Setting work as wallpaper on KDE and Hyprland</p>
        <p>- Profile view</p>
        </description>
    </release>
    <release version="0.1.0" date="2025-06-03">
        <url
                type="details"
            >https://github.com/MicrogamerCz/Piki/releases/tag/0.1</url>
        <description>
            <p>Initial release</p>
        </description>
        </release>
    </releases>
 </component>
